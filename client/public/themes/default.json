{
  "palette": {
    "mode": "light",
    "primary": {
      "main": "#000000",
      "contrastText": "#ffffff"
    },
    "secondary": {
      "main": "#c1fbd4",
      "contrastText": "#000000"
    },
    "background": {
      "default": "#fbfbf5",
      "paper": "#ffffff"
    },
    "text": {
      "primary": "#000000",
      "secondary": "#71717a"
    },
    "divider": "#e4e4e7"
  },
  "typography": {
    "fontFamily": "Inter Variable, Inter, Helvetica, Arial, sans-serif",
    "h1": {
      "fontFamily": "Neue Haas Grotesk Display, Helvetica, Arial, sans-serif",
      "fontSize": "55px",
      "fontWeight": 330,
      "lineHeight": 1.16,
      "letterSpacing": "0px"
    },
    "h2": {
      "fontFamily": "Neue Haas Grotesk Display, Helvetica, Arial, sans-serif",
      "fontSize": "48px",
      "fontWeight": 330,
      "lineHeight": 1.14,
      "letterSpacing": "0px"
    },
    "h3": {
      "fontFamily": "Neue Haas Grotesk Display, Helvetica, Arial, sans-serif",
      "fontSize": "28px",
      "fontWeight": 500,
      "lineHeight": 1.28,
      "letterSpacing": "0.42px"
    },
    "h4": {
      "fontFamily": "Neue Haas Grotesk Display, Helvetica, Arial, sans-serif",
      "fontSize": "24px",
      "fontWeight": 400,
      "lineHeight": 1.14,
      "letterSpacing": "0.36px"
    },
    "h5": {
      "fontFamily": "Neue Haas Grotesk Display, Helvetica, Arial, sans-serif",
      "fontSize": "20px",
      "fontWeight": 500,
      "lineHeight": 1.4,
      "letterSpacing": "0.3px"
    },
    "h6": {
      "fontFamily": "Neue Haas Grotesk Display, Helvetica, Arial, sans-serif",
      "fontSize": "18px",
      "fontWeight": 500,
      "lineHeight": 1.25,
      "letterSpacing": "0.72px"
    },
    "subtitle1": {
      "fontSize": "16px",
      "fontWeight": 550,
      "lineHeight": 1.5
    },
    "subtitle2": {
      "fontSize": "14px",
      "fontWeight": 550,
      "lineHeight": 1.49
    },
    "body1": {
      "fontSize": "16px",
      "fontWeight": 420,
      "lineHeight": 1.5
    },
    "body2": {
      "fontSize": "14px",
      "fontWeight": 420,
      "lineHeight": 1.49
    },
    "button": {
      "fontSize": "16px",
      "fontWeight": 550,
      "lineHeight": 1.5,
      "textTransform": "none"
    },
    "caption": {
      "fontSize": "14px",
      "fontWeight": 500,
      "lineHeight": 1.49,
      "letterSpacing": "0.28px"
    },
    "overline": {
      "fontSize": "12px",
      "fontWeight": 400,
      "lineHeight": 1.2,
      "letterSpacing": "0.72px"
    }
  },
  "shape": {
    "borderRadius": 8
  },
  "components": {
    "MuiCssBaseline": {
      "styleOverrides": {
        "body": {
          "fontFeatureSettings": "\"ss03\""
        }
      }
    },
    "MuiButton": {
      "defaultProps": {
        "disableElevation": true
      },
      "styleOverrides": {
        "root": {
          "borderRadius": 9999,
          "paddingTop": 12,
          "paddingBottom": 12,
          "paddingLeft": 24,
          "paddingRight": 24
        }
      }
    },
    "MuiChip": {
      "styleOverrides": {
        "root": {
          "borderRadius": 9999
        }
      }
    },
    "MuiOutlinedInput": {
      "styleOverrides": {
        "root": {
          "borderRadius": 8
        }
      }
    },
    "MuiPaper": {
      "styleOverrides": {
        "elevation1": {
          "boxShadow": "0 8px 8px rgba(0,0,0,0.1), 0 4px 4px rgba(0,0,0,0.1), 0 2px 2px rgba(0,0,0,0.1), 0 0 0 1px rgba(0,0,0,0.1)"
        }
      }
    }
  }
}